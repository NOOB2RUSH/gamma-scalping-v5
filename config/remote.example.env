# Copy this file to config/remote.env and fill in values for your server.
# config/remote.env is intentionally ignored by git.

# Required SSH target. Examples:
# REMOTE_HOST="user@10.0.0.12"
# REMOTE_HOST="research-box"
REMOTE_HOST=""

# Required absolute project directory on the remote server.
REMOTE_PROJECT_DIR="/home/user/gamma_scalping_v5"

# Python command available on the remote server. If REMOTE_VENV is set,
# this command is used after activating the virtualenv.
REMOTE_PYTHON="python3"

# Optional virtualenv path relative to REMOTE_PROJECT_DIR or absolute.
# Leave empty to use REMOTE_PYTHON directly.
REMOTE_VENV=".venv"

# Optimization defaults used by scripts/remote_optimization.sh run.
OPT_SPACE="config/optimization.default.json"
OPT_STAGE="vol_timing"
OPT_STUDY_ID="remote_vol_timing"
OPT_MAX_TRIALS=""

# Data is often large and should normally live on the remote server already.
# Set SYNC_DATA=1 only for small smoke-test datasets.
SYNC_DATA=0

# Set SYNC_RESULTS=1 only when you intentionally want local result files
# mirrored to the server. Normal remote runs should keep this at 0.
SYNC_RESULTS=0

# Extra options can be appended as words.
SSH_OPTS="-o ServerAliveInterval=60 -o ServerAliveCountMax=5"
RSYNC_OPTS="-az --delete"

